# ============================================================================
# WORKSHOP CONFIGURATION
# ============================================================================

# Default model for all agents in the workshop
# Examples: "anthropic:claude-haiku-4-5", "openai:gpt-5-mini", "openai:gpt-4o"
# Can be overridden per-agent in factory functions
WORKSHOP_MODEL="anthropic:claude-haiku-4-5"

# ShopMind runtime mode. Keep single/deterministic by default.
# Set SHOPMIND_AGENT_MODE="multi" to use the V3 read-only multi-agent path.
# Set SHOPMIND_SUPERVISOR_ROUTER="llm" to route with WORKSHOP_MODEL and
# deterministic fallback when the model/provider is unavailable.
# SHOPMIND_AGENT_MODE="single"
# SHOPMIND_SUPERVISOR_ROUTER="deterministic"

# Embedding provider for document vectorstore
# Options: "huggingface" (default, local model, no API key) or "openai" (requires OPENAI_API_KEY)
# Note: Changing providers requires rebuilding the vectorstore:
#   conda run -n pythonLearn D:\DL\Anaconda3\envs\pythonLearn\python.exe data/data_generation/build_vectorstore.py
# EMBEDDING_PROVIDER="huggingface"

# ============================================================================
# SHOPMIND V2 POSTGRESQL / PGVECTOR CONFIGURATION
# ============================================================================

# Local PostgreSQL + pgvector database started by docker-compose.yml.
# This is additive for V2 infrastructure work; existing V1 tools still read
# the SQLite database until the data migration and tool refactor are completed.
DATABASE_URL="postgresql+psycopg://retailpilot:retailpilot@127.0.0.1:5432/retailpilot?connect_timeout=5"
TEST_DATABASE_URL="postgresql+psycopg://retailpilot:retailpilot@127.0.0.1:5432/retailpilot_test?connect_timeout=5"

# Default dimension for sentence-transformers/all-mpnet-base-v2.
# If EMBEDDING_PROVIDER=openai with text-embedding-3-small, use 1536 instead.
VECTOR_DIMENSION="768"

# ============================================================================
# LANGSMITH CONFIGURATION
# ============================================================================

# Optional for LangSmith tracing and experiment tracking
LANGSMITH_TRACING="true"
LANGSMITH_PROJECT="langsmith-agent-lifecycle-workshop"
LANGSMITH_API_KEY="<langsmith-api-key>"
LANGSMITH_ENDPOINT="<langsmith-endpoint>" # defaults to https://api.smith.langchain.com if using cloud

# ============================================================================
# MODEL PROVIDER API KEYS
# ============================================================================

# If using OpenAI 
OPENAI_API_KEY="<openai-api-key>"
OPENAI_BASE_URL="<openai-base-url>" # Optional, if different from the default 

# If using Azure OpenAI
AZURE_OPENAI_API_KEY="<azure-openai-api-key>"
AZURE_OPENAI_ENDPOINT="<azure-openai-endpoint>"
AZURE_OPENAI_API_VERSION=""

# If using Anthropic
ANTHROPIC_API_KEY="<anthropic-api-key>"

# If using AWS
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION_NAME=""
AWS_MODEL_ARN=""

# ============================================================================
# DEPLOYMENT CONFIGURATION (Optional)
# ============================================================================

# LangGraph deployment URL for simulation system
# Only needed if running automated simulations against deployed graphs
# Example: "https://your-deployment.us.langgraph.app"
LANGGRAPH_DEPLOYMENT_URL=""
